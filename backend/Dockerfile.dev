FROM node:24-alpine

WORKDIR /app

COPY package*.json ./

# Must be present before 'npm ci' so the postinstall script (prisma generate) can run
COPY prisma ./prisma/

RUN npm ci

# Config files required by the NestJS compiler and Prisma CLI
COPY tsconfig*.json nest-cli.json prisma.config.ts ./

EXPOSE 3000

# Source code is mounted as a volume — no COPY . . or build step needed.
# Migrations and seed run on every start, then NestJS watch mode takes over.
CMD ["sh", "-c", "npx prisma migrate deploy && npx prisma db seed && npm run start:dev"]
