# PostgreSQL Docker Compose credentials
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=task_manager

# PostgreSQL connection string using the above credentials
DATABASE_URL=postgres://myuser:mypassword@db:5432/task_manager

# PostgreSQL connection for _local_ backend e2e tests (separate database)
# NOTE: The test database name is fixed as 'test_task_manager' in docker-compose.dev.yml
DATABASE_URL_TEST=postgres://myuser:mypassword@localhost:5432/test_task_manager

# If needed, for local db access outside Docker
DATABASE_URL_LOCAL=postgres://myuser:mypassword@localhost:5432/task_manager

# NestJS backend port (defaults to 3000 if not set)
PORT=3000

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=your_super_secret_jwt_string_here

# Google AI (Gemini) API key — obtain a free tier key from https://aistudio.google.com/
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Vite frontend — base URL for the API proxy (used in development)
VITE_API_URL=http://localhost:3000
