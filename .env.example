# PostgreSQL connection (used by Prisma at runtime)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME

# PostgreSQL connection for e2e tests (separate database)
DATABASE_URL_TEST=postgresql://USER:PASSWORD@HOST:5432/DB_NAME_test

# Local direct connection (used for local development outside Docker)
DATABASE_URL_LOCAL=postgresql://USER:PASSWORD@localhost:5432/DB_NAME

# PostgreSQL Docker Compose credentials (used by the postgres service in docker-compose.yml)
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# NestJS backend port (defaults to 3000 if not set)
PORT=3000

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET=

# Google AI (Gemini) API key — obtain a free tier key from https://aistudio.google.com/
GOOGLE_AI_API_KEY=

# Vite frontend — base URL for the API proxy (used in development)
VITE_API_URL=http://localhost:3000
